{
  "info": {
    "name": "TransitOps — Vehicles",
    "description": "Vehicle registry endpoints. Run '0. Setup' requests first — they store the JWT in collection variables, so every later request is authorized automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" },
    { "key": "fmToken", "value": "" },
    { "key": "dpToken", "value": "" },
    { "key": "vehicleId", "value": "" },
    { "key": "reg", "value": "" }
  ],
  "item": [
    {
      "name": "0. Setup",
      "item": [
        {
          "name": "Register fleet manager (saves fmToken)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Unique email per run so re-running never collides.",
                  "pm.collectionVariables.set('fmEmail', 'fm' + Date.now() + '@transitops.test');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const d = pm.response.json();",
                  "pm.test('registered', () => pm.expect(pm.response.code).to.eql(201));",
                  "pm.collectionVariables.set('fmToken', d.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Fleet Manager\",\n  \"email\": \"{{fmEmail}}\",\n  \"password\": \"pass1234\",\n  \"role\": \"fleet_manager\"\n}"
            }
          }
        },
        {
          "name": "Register dispatcher (saves dpToken)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.collectionVariables.set('dpEmail', 'dp' + Date.now() + '@transitops.test');"]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const d = pm.response.json();",
                  "pm.test('registered', () => pm.expect(pm.response.code).to.eql(201));",
                  "pm.collectionVariables.set('dpToken', d.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Dispatcher\",\n  \"email\": \"{{dpEmail}}\",\n  \"password\": \"pass1234\",\n  \"role\": \"dispatcher\"\n}"
            }
          }
        },
        {
          "name": "Login (re-issue fmToken)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const d = pm.response.json();",
                  "if (d.accessToken) pm.collectionVariables.set('fmToken', d.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{fmEmail}}\",\n  \"password\": \"pass1234\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "1. Happy path",
      "item": [
        {
          "name": "POST create vehicle (201, saves vehicleId)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// registration_number is varchar(20) — keep the generated value short.",
                  "pm.collectionVariables.set('reg', 'GJ05-VAN-' + String(Date.now()).slice(-6));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const d = pm.response.json();",
                  "pm.test('201 created', () => pm.expect(pm.response.code).to.eql(201));",
                  "pm.test('starts available', () => pm.expect(d.vehicle.status).to.eql('available'));",
                  "pm.collectionVariables.set('vehicleId', d.vehicle.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{fmToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/vehicles", "host": ["{{baseUrl}}"], "path": ["vehicles"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"registrationNumber\": \"{{reg}}\",\n  \"name\": \"Van-05\",\n  \"model\": \"Force Traveller\",\n  \"type\": \"Van\",\n  \"region\": \"West\",\n  \"maxLoadCapacity\": 500,\n  \"odometer\": 12000,\n  \"acquisitionCost\": 800000\n}"
            }
          }
        },
        {
          "name": "GET list all vehicles",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{fmToken}}" }],
            "url": { "raw": "{{baseUrl}}/vehicles", "host": ["{{baseUrl}}"], "path": ["vehicles"] }
          }
        },
        {
          "name": "GET ?status=available (dispatch dropdown)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const d = pm.response.json();",
                  "pm.test('only available vehicles returned', () =>",
                  "  pm.expect(d.vehicles.every(v => v.status === 'available')).to.be.true);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{dpToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/vehicles?status=available",
              "host": ["{{baseUrl}}"],
              "path": ["vehicles"],
              "query": [{ "key": "status", "value": "available" }]
            }
          }
        },
        {
          "name": "GET filters (type / region / search)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{fmToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/vehicles?type=Van&region=West&search=GJ05",
              "host": ["{{baseUrl}}"],
              "path": ["vehicles"],
              "query": [
                { "key": "type", "value": "Van" },
                { "key": "region", "value": "West" },
                { "key": "search", "value": "GJ05" }
              ]
            }
          }
        },
        {
          "name": "GET vehicle by id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{fmToken}}" }],
            "url": { "raw": "{{baseUrl}}/vehicles/{{vehicleId}}", "host": ["{{baseUrl}}"], "path": ["vehicles", "{{vehicleId}}"] }
          }
        },
        {
          "name": "PUT update vehicle (200)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{fmToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/vehicles/{{vehicleId}}", "host": ["{{baseUrl}}"], "path": ["vehicles", "{{vehicleId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"maxLoadCapacity\": 750,\n  \"model\": \"Force Traveller 3350\",\n  \"region\": \"North\"\n}"
            }
          }
        },
        {
          "name": "PUT status -> retired (200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const d = pm.response.json();",
                  "pm.test('retired', () => pm.expect(d.vehicle.status).to.eql('retired'));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{fmToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/vehicles/{{vehicleId}}/status", "host": ["{{baseUrl}}"], "path": ["vehicles", "{{vehicleId}}", "status"] },
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"retired\"\n}" }
          }
        },
        {
          "name": "PUT status -> available (un-retire)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{fmToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/vehicles/{{vehicleId}}/status", "host": ["{{baseUrl}}"], "path": ["vehicles", "{{vehicleId}}", "status"] },
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"available\"\n}" }
          }
        }
      ]
    },
    {
      "name": "2. Business rules (should FAIL)",
      "item": [
        {
          "name": "Duplicate registration number -> 409",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('409 conflict', () => pm.expect(pm.response.code).to.eql(409));"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{fmToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/vehicles", "host": ["{{baseUrl}}"], "path": ["vehicles"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"registrationNumber\": \"{{reg}}\",\n  \"name\": \"Duplicate\",\n  \"type\": \"Van\",\n  \"maxLoadCapacity\": 300\n}"
            }
          }
        },
        {
          "name": "Duplicate reg, different case -> 409",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Same registration number as the created vehicle, lowercased.",
                  "pm.collectionVariables.set('regLower', pm.collectionVariables.get('reg').toLowerCase());"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('case-insensitive uniqueness', () => pm.expect(pm.response.code).to.eql(409));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{fmToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/vehicles", "host": ["{{baseUrl}}"], "path": ["vehicles"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"registrationNumber\": \"{{regLower}}\",\n  \"name\": \"Case test\",\n  \"type\": \"Van\",\n  \"maxLoadCapacity\": 300\n}"
            }
          }
        },
        {
          "name": "Registration number > 20 chars -> 400",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('400, not a 500 driver error', () => pm.expect(pm.response.code).to.eql(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{fmToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/vehicles", "host": ["{{baseUrl}}"], "path": ["vehicles"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"registrationNumber\": \"THIS-REG-NUMBER-IS-WAY-TOO-LONG-FOR-THE-COLUMN\",\n  \"name\": \"Too long\",\n  \"type\": \"Van\",\n  \"maxLoadCapacity\": 300\n}"
            }
          }
        },
        {
          "name": "Non-numeric id -> 400",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('400, not a 500 driver error', () => pm.expect(pm.response.code).to.eql(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{fmToken}}" }],
            "url": { "raw": "{{baseUrl}}/vehicles/abc", "host": ["{{baseUrl}}"], "path": ["vehicles", "abc"] }
          }
        },
        {
          "name": "Dispatcher tries to create -> 403 (RBAC)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('403 forbidden', () => pm.expect(pm.response.code).to.eql(403));"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{dpToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/vehicles", "host": ["{{baseUrl}}"], "path": ["vehicles"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"registrationNumber\": \"RBAC-TEST-01\",\n  \"name\": \"Should not exist\",\n  \"type\": \"Van\",\n  \"maxLoadCapacity\": 100\n}"
            }
          }
        },
        {
          "name": "No token -> 401",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('401 unauthorized', () => pm.expect(pm.response.code).to.eql(401));"]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/vehicles", "host": ["{{baseUrl}}"], "path": ["vehicles"] }
          }
        },
        {
          "name": "Capacity = 0 -> 400",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('400 bad request', () => pm.expect(pm.response.code).to.eql(400));"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{fmToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/vehicles", "host": ["{{baseUrl}}"], "path": ["vehicles"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"registrationNumber\": \"BAD-CAP-01\",\n  \"name\": \"Bad capacity\",\n  \"type\": \"Van\",\n  \"maxLoadCapacity\": 0\n}"
            }
          }
        },
        {
          "name": "Missing required fields -> 400",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{fmToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/vehicles", "host": ["{{baseUrl}}"], "path": ["vehicles"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"No reg number\"\n}" }
          }
        },
        {
          "name": "Invalid status filter -> 400",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{fmToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/vehicles?status=bogus",
              "host": ["{{baseUrl}}"],
              "path": ["vehicles"],
              "query": [{ "key": "status", "value": "bogus" }]
            }
          }
        },
        {
          "name": "Set status via PUT /:id -> 400 (wrong endpoint)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('rejects status on update endpoint', () => pm.expect(pm.response.code).to.eql(400));"]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{fmToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/vehicles/{{vehicleId}}", "host": ["{{baseUrl}}"], "path": ["vehicles", "{{vehicleId}}"] },
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"on_trip\"\n}" }
          }
        },
        {
          "name": "Manual status = on_trip -> 400 (owned by trips)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('on_trip not settable by hand', () => pm.expect(pm.response.code).to.eql(400));"]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{fmToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/vehicles/{{vehicleId}}/status", "host": ["{{baseUrl}}"], "path": ["vehicles", "{{vehicleId}}", "status"] },
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"on_trip\"\n}" }
          }
        },
        {
          "name": "Manual status = in_shop -> 400 (owned by maintenance)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{fmToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/vehicles/{{vehicleId}}/status", "host": ["{{baseUrl}}"], "path": ["vehicles", "{{vehicleId}}", "status"] },
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"in_shop\"\n}" }
          }
        },
        {
          "name": "Odometer rollback -> 400",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{fmToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/vehicles/{{vehicleId}}", "host": ["{{baseUrl}}"], "path": ["vehicles", "{{vehicleId}}"] },
            "body": { "mode": "raw", "raw": "{\n  \"odometer\": 1\n}" }
          }
        },
        {
          "name": "Unknown vehicle id -> 404",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('404 not found', () => pm.expect(pm.response.code).to.eql(404));"]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{fmToken}}" }],
            "url": { "raw": "{{baseUrl}}/vehicles/999999", "host": ["{{baseUrl}}"], "path": ["vehicles", "999999"] }
          }
        }
      ]
    }
  ]
}
